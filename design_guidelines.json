{
  "brand_identity": {
    "name": "KhajurKart",
    "tone": "Luxury, Organic, Heritage, Premium",
    "archetype": "The Royal Merchant (Jewel & Luxury)",
    "description": "A premium destination for the world's finest dates, dry fruits, and spices."
  },
  "typography": {
    "fonts": [
      {
        "family": "Playfair Display",
        "usage": "Headings, Hero Titles",
        "weights": ["400", "700"],
        "import_url": "https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      },
      {
        "family": "Cormorant Garamond",
        "usage": "Subheadings, Accents, Quotes",
        "weights": ["400", "600", "700"],
        "import_url": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&display=swap"
      },
      {
        "family": "Manrope",
        "usage": "Body text, UI elements, Buttons",
        "weights": ["400", "500", "600"],
        "import_url": "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600&display=swap"
      }
    ],
    "rules": {
      "h1": "font-serif text-5xl md:text-7xl font-medium tracking-tight leading-tight",
      "h2": "font-serif text-3xl md:text-5xl font-medium tracking-tight text-primary",
      "h3": "font-serif text-2xl md:text-3xl font-medium text-primary/90",
      "body": "font-sans text-base leading-relaxed text-foreground/80 tracking-wide",
      "button": "font-sans uppercase tracking-widest text-sm font-semibold",
      "price": "font-serif text-xl text-secondary font-bold"
    }
  },
  "colors": {
    "palette": {
      "primary": "#0F3D2E",
      "primary_foreground": "#F5F0E6",
      "secondary": "#C6A962",
      "secondary_foreground": "#0F3D2E",
      "background": "#F5F0E6",
      "foreground": "#2B2B2B",
      "accent": "#D4C5A5",
      "muted": "#E6E1D6",
      "border": "#D4C5A5"
    },
    "tailwind_config": {
      "colors": {
        "khajur": {
          "primary": "#0F3D2E",
          "gold": "#C6A962",
          "cream": "#F5F0E6",
          "dark": "#1A1A1A",
          "muted": "#8C8C8C"
        }
      }
    },
    "gradients": {
      "gold_shimmer": "linear-gradient(45deg, #C6A962 0%, #E5D19A 50%, #C6A962 100%)",
      "dark_overlay": "linear-gradient(to bottom, rgba(15, 61, 46, 0.2), rgba(15, 61, 46, 0.8))"
    }
  },
  "layout_strategies": {
    "container": "max-w-7xl mx-auto px-6 md:px-12",
    "section_spacing": "py-20 md:py-32",
    "grid_system": {
      "bento_hero": "grid grid-cols-1 md:grid-cols-12 gap-6",
      "product_grid": "grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8"
    },
    "z_index": {
      "nav": "z-50",
      "modal": "z-50",
      "overlay": "z-40",
      "dropdown": "z-40"
    }
  },
  "visual_enhancers": {
    "border_radius": "rounded-none",
    "shadows": {
      "card": "0 10px 30px -10px rgba(15, 61, 46, 0.1)",
      "hover": "0 20px 40px -12px rgba(198, 169, 98, 0.2)"
    },
    "textures": {
      "grain": "url(\"data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E\")"
    },
    "animations": {
      "hover_lift": "transition-all duration-300 ease-out hover:-translate-y-1 hover:shadow-lg",
      "fade_in": "animate-in fade-in duration-700",
      "slide_up": "animate-in slide-in-from-bottom-8 duration-700"
    }
  },
  "components": {
    "buttons": {
      "primary": "bg-primary text-cream hover:bg-primary/90 rounded-sm px-8 py-3 uppercase tracking-widest text-xs font-bold transition-all border border-transparent hover:border-gold",
      "secondary": "bg-transparent border border-primary text-primary hover:bg-primary hover:text-cream rounded-sm px-8 py-3 uppercase tracking-widest text-xs font-bold transition-all",
      "gold": "bg-secondary text-primary hover:bg-secondary/90 hover:shadow-[0_0_15px_rgba(198,169,98,0.4)] rounded-sm px-8 py-3 uppercase tracking-widest text-xs font-bold transition-all"
    },
    "cards": {
      "product": "group relative bg-white border border-transparent hover:border-gold/30 transition-all duration-500 overflow-hidden",
      "feature": "p-8 border border-primary/10 bg-cream hover:bg-white transition-colors duration-300 text-center"
    },
    "inputs": {
      "default": "bg-transparent border-b border-primary/20 focus:border-primary rounded-none px-0 py-3 focus:ring-0 outline-none transition-colors placeholder:text-primary/40"
    }
  },
  "assets": {
    "images": {
      "hero_slider": [
        {
          "url": "https://images.pexels.com/photos/18740976/pexels-photo-18740976.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
          "alt": "Luxury Dates Platter"
        },
        {
          "url": "https://images.pexels.com/photos/15807109/pexels-photo-15807109.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
          "alt": "Silver Bowl Dates"
        },
        {
          "url": "https://images.pexels.com/photos/33654800/pexels-photo-33654800.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
          "alt": "Premium Saffron"
        }
      ],
      "categories": {
        "dates": "https://images.pexels.com/photos/15807109/pexels-photo-15807109.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "nuts": "https://images.pexels.com/photos/20377557/pexels-photo-20377557.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "spices": "https://images.pexels.com/photos/4198755/pexels-photo-4198755.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "stuffed_dates": "https://images.pexels.com/photos/29609856/pexels-photo-29609856.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "gourmet": "https://images.pexels.com/photos/31496295/pexels-photo-31496295.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940",
        "powder": "https://images.unsplash.com/photo-1606914469276-31bc4103c50c?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NTY2NzB8MHwxfHNlYXJjaHwyfHxsdXh1cnklMjBzcGljZXMlMjBwb3dkZXIlMjBhcnRpc3RpYyUyMHNwb29ufGVufDB8fHx8MTc3MTczOTQ4N3ww&ixlib=rb-4.1.0&q=85"
      },
      "placeholders": {
        "logo": "https://images.unsplash.com/photo-1739055547874-4fe440a2bfea?crop=entropy&cs=srgb&fm=jpg&ixid=M3w3NDk1Nzd8MHwxfHNlYXJjaHwxfHxsdXh1cnklMjBnb2xkJTIwbWFuZGFsYSUyMGxvZ28lMjB2ZWN0b3IlMjBibGFjayUyMGJhY2tncm91bmR8ZW58MHx8fHwxNzcxNzM5NTA0fDA&ixlib=rb-4.1.0&q=85",
        "gift_box": "https://images.pexels.com/photos/31496295/pexels-photo-31496295.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=650&w=940"
      }
    },
    "icons": {
      "library": "lucide-react",
      "style": "stroke-[1.5px]"
    }
  },
  "accessibility": {
    "contrast_check": "Ensure Gold text (#C6A962) is only used on Dark Green (#0F3D2E) or Black backgrounds. Use Dark Green text on Cream backgrounds.",
    "focus_states": "focus:ring-2 focus:ring-offset-2 focus:ring-secondary",
    "motion": "Respect prefers-reduced-motion"
  },
  "universal_guidelines": [
    "Use 'lenis' for smooth scrolling.",
    "Do NOT use gradients for main backgrounds, use solid colors or subtle grain textures.",
    "Buttons should have sharp edges (rounded-sm or rounded-none) for a premium feel.",
    "Images must have 'alt' tags.",
    "Use 'sonner' for toast notifications.",
    "Interactive elements must have 'data-testid' attributes."
  ],
  "instructions_to_main_agent": "Implement the design system first by updating tailwind.config.js and index.css. Then build the layout components (Navbar, Footer). Proceed to build pages one by one. Use the asset URLs provided for the respective sections. Ensure the 'KhajurKart' brand name is prominent and the tone is strictly luxury/premium."
}